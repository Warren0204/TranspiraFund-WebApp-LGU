rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ════════════════════════════════════════════════════════════════
    //  HELPER FUNCTIONS
    // ════════════════════════════════════════════════════════════════

    function getUserRole() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
        : '';
    }

    function isAuthenticated() {
      return request.auth != null;
    }

    function hasRole(roles) {
      return isAuthenticated() && getUserRole() in roles;
    }


    // ════════════════════════════════════════════════════════════════
    //  CATEGORY 1 — USER MANAGEMENT
    // ════════════════════════════════════════════════════════════════

    match /users/{userId} {
      allow read: if isAuthenticated() &&
                     (request.auth.uid == userId ||
                      hasRole(['MIS', 'HCSD']));
      allow write: if false;
    }


    // ════════════════════════════════════════════════════════════════
    //  CATEGORY 2 — PROJECT DATA
    // ════════════════════════════════════════════════════════════════

    match /projects/{projectId} {
      allow read: if hasRole(['MIS', 'MAYOR', 'HCSD', 'CPDO', 'PROJ_ENG']);
      allow create, update, delete: if false;

      match /milestones/{milestoneId} {
        allow read:   if hasRole(['MIS', 'MAYOR', 'HCSD', 'CPDO', 'PROJ_ENG']);
        allow update: if hasRole(['PROJ_ENG']);
        allow create, delete: if false;
      }
    }


    // ════════════════════════════════════════════════════════════════
    //  CATEGORY 3 — AUDIT TRAILS
    //  Three scoped sub-paths under one parent collection.
    //  Named after the role that owns each scope.
    // ════════════════════════════════════════════════════════════════

    // auditTrails/mis/entries/{logId}
    //   MIS-scope events: account provisioning, OTP, password changes, stats
    //   Read: MIS only | Write: Cloud Functions (Admin SDK) only

    match /auditTrails/mis/entries/{logId} {
      allow read:  if hasRole(['MIS']);
      allow write: if false;
    }

    // auditTrails/hcsd/entries/{logId}
    //   HCSD-scope events: project created, PROJ_ENG account created/deleted
    //   Read: HCSD only | Write: Cloud Functions (Admin SDK) only

    match /auditTrails/hcsd/entries/{logId} {
      allow read:  if hasRole(['HCSD']);
      allow write: if false;
    }

    // auditTrails/mobile/entries/{logId}
    //   PROJ_ENG mobile app activity (login, field actions)
    //   Read: MIS + HCSD for monitoring | Create: PROJ_ENG mobile app only

    match /auditTrails/mobile/entries/{logId} {
      allow read:   if hasRole(['MIS', 'HCSD', 'PROJ_ENG']);
      allow create: if hasRole(['PROJ_ENG']);
      allow update, delete: if false;
    }


    // ════════════════════════════════════════════════════════════════
    //  CATEGORY 4 — AUTHENTICATION / OTP
    // ════════════════════════════════════════════════════════════════

    match /otpCodes/{uid} {
      allow read, write: if false;
    }

    match /passwordResets/{docId} {
      allow read, write: if false;
    }

    match /passwordResetOtps/{docId} {
      allow read, write: if false;
    }

    match /passwordResetCooldowns/{docId} {
      allow read, write: if false;
    }


    // ════════════════════════════════════════════════════════════════
    //  CATEGORY 5 — NOTIFICATIONS
    // ════════════════════════════════════════════════════════════════

    match /notifications/{notifId} {
      allow read:   if hasRole(['MIS', 'MAYOR', 'HCSD', 'CPDO', 'PROJ_ENG']);
      allow update: if hasRole(['MIS', 'MAYOR', 'HCSD', 'CPDO', 'PROJ_ENG']);
      allow create, delete: if false;
    }


    // ════════════════════════════════════════════════════════════════
    //  CATEGORY 6 — PUBLIC DATA
    // ════════════════════════════════════════════════════════════════

    match /stats/{docId} {
      allow read:  if docId == 'public';
      allow write: if false;
    }


    // ════════════════════════════════════════════════════════════════
    //  DEFAULT — Deny everything not explicitly matched above
    // ════════════════════════════════════════════════════════════════

    match /{document=**} {
      allow read, write: if false;
    }

  }
}
