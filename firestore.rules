rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ════════════════════════════════════════════════════════════════
    //  HELPER FUNCTIONS
    // ════════════════════════════════════════════════════════════════

    function getUserRole() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
        : '';
    }

    function isAuthenticated() {
      return request.auth != null;
    }

    function hasRole(roles) {
      return isAuthenticated() && getUserRole() in roles;
    }


    // ════════════════════════════════════════════════════════════════
    //  CATEGORY 1 — USER MANAGEMENT
    // ════════════════════════════════════════════════════════════════

    match /users/{userId} {
      allow read: if isAuthenticated() &&
                     (request.auth.uid == userId ||
                      hasRole(['MIS', 'HCSD']));
      allow write: if false;
    }


    // ════════════════════════════════════════════════════════════════
    //  CATEGORY 2 — PROJECT DATA
    //
    //  Admin roles (MIS/MAYOR/HCSD/CPDO) see all projects.
    //  Project Engineers see only projects assigned to them
    //  (document's `projectEngineer` field == their own UID).
    // ════════════════════════════════════════════════════════════════

    function isAssignedEngineer(projectData) {
      return hasRole(['PROJ_ENG']) &&
             projectData.projectEngineer == request.auth.uid;
    }

    match /projects/{projectId} {
      allow read: if hasRole(['MIS', 'MAYOR', 'HCSD', 'CPDO']) ||
                     isAssignedEngineer(resource.data);
      allow create, update, delete: if false;

      match /milestones/{milestoneId} {
        allow read:   if hasRole(['MIS', 'MAYOR', 'HCSD', 'CPDO']) ||
                         isAssignedEngineer(get(/databases/$(database)/documents/projects/$(projectId)).data);
        allow update: if isAssignedEngineer(get(/databases/$(database)/documents/projects/$(projectId)).data);
        allow create, delete: if false;
      }
    }


    // ════════════════════════════════════════════════════════════════
    //  CATEGORY 3 — AUDIT TRAILS
    //  Three scoped sub-paths under one parent collection.
    //  Named after the role that owns each scope.
    // ════════════════════════════════════════════════════════════════

    // auditTrails/mis/entries/{logId}
    //   MIS-scope events: account provisioning, OTP, password changes, stats
    //   Read: MIS only | Write: Cloud Functions (Admin SDK) only

    match /auditTrails/mis/entries/{logId} {
      allow read:  if hasRole(['MIS']);
      allow write: if false;
    }

    // auditTrails/hcsd/entries/{logId}
    //   HCSD-scope events: project created, PROJ_ENG account created/deleted
    //   Read: HCSD only | Write: Cloud Functions (Admin SDK) only

    match /auditTrails/hcsd/entries/{logId} {
      allow read:  if hasRole(['HCSD']);
      allow write: if false;
    }

    // auditTrails/mobile/entries/{logId}
    //   PROJ_ENG mobile self-audit. The web side never reads this. Mobile
    //   activity surfaces to HCSD only via notifications (category: "field"),
    //   fanned out by the onMobileAuditCreated trigger. This keeps the web
    //   audit trail strictly "actions this account performed" and routes
    //   field activity through the Notifications page instead.
    //   Read/Create: PROJ_ENG only.

    match /auditTrails/mobile/entries/{logId} {
      allow read:   if hasRole(['PROJ_ENG']);
      allow create: if hasRole(['PROJ_ENG']);
      allow update, delete: if false;
    }


    // ════════════════════════════════════════════════════════════════
    //  CATEGORY 4 — AUTHENTICATION / OTP
    // ════════════════════════════════════════════════════════════════

    match /otpCodes/{uid} {
      allow read, write: if false;
    }

    match /passwordResets/{docId} {
      allow read, write: if false;
    }

    match /passwordResetOtps/{docId} {
      allow read, write: if false;
    }

    match /passwordResetCooldowns/{docId} {
      allow read, write: if false;
    }


    // ════════════════════════════════════════════════════════════════
    //  CATEGORY 5 — NOTIFICATIONS
    // ════════════════════════════════════════════════════════════════

    match /notifications/{notifId} {
      allow read:   if isAuthenticated() && resource.data.recipientUid == request.auth.uid;
      allow update: if isAuthenticated()
                    && resource.data.recipientUid == request.auth.uid
                    && request.resource.data.diff(resource.data).affectedKeys()
                         .hasOnly(['isRead', 'dismissedAt']);
      allow create, delete: if false;
    }


    // ════════════════════════════════════════════════════════════════
    //  CATEGORY 6 — RATE LIMITS (Cloud Functions bookkeeping)
    // ════════════════════════════════════════════════════════════════

    match /ntpRateLimits/{uid} {
      allow read, write: if false;
    }

    match /projectCreateRateLimits/{uid} {
      allow read, write: if false;
    }


    // ════════════════════════════════════════════════════════════════
    //  CATEGORY 7 — PUBLIC DATA
    // ════════════════════════════════════════════════════════════════

    match /stats/{docId} {
      allow read:  if docId == 'public';
      allow write: if false;
    }


    // ════════════════════════════════════════════════════════════════
    //  DEFAULT — Deny everything not explicitly matched above
    // ════════════════════════════════════════════════════════════════

    match /{document=**} {
      allow read, write: if false;
    }

  }
}
