rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Web + Admin: profile photo upload (single file per user, overwritten).
    // Synced via updateProfilePhoto callable so Firestore + Auth stay in sync.
    // Profile photos are user-scoped, not tenant-scoped: the path keys on
    // userId, and user docs already enforce tenant isolation in Firestore.
    match /profile-photos/{userId} {
      allow read:   if request.auth != null;
      allow write:  if request.auth != null
                    && request.auth.uid == userId
                    && request.resource.size < 5 * 1024 * 1024
                    && request.resource.contentType.matches('image/.*');
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    // Mobile: geotagged proof-of-work photos per milestone.
    // Filename = {capturedAt}.jpg. Create-only; admin mutations go via CF.
    //
    // Tenant verification: read AND create require the parent project's
    // tenantId to match the caller's claim. The firestore.get cost is paid
    // here because the parent project doc is the only authoritative source
    // of the tenant binding. Create additionally requires the caller to
    // be the assigned project engineer; that check needs the same parent
    // doc, so the lookup is amortized.
    match /projects/{projectId}/milestones/{milestoneId}/proofs/{filename} {
      allow read:   if request.auth != null
                    && firestore.get(
                         /databases/(default)/documents/projects/$(projectId)
                       ).data.tenantId == request.auth.token.tenantId;
      allow create: if request.auth != null
                    && firestore.get(
                         /databases/(default)/documents/projects/$(projectId)
                       ).data.tenantId == request.auth.token.tenantId
                    && request.auth.uid == firestore.get(
                         /databases/(default)/documents/projects/$(projectId)
                       ).data.projectEngineer
                    && request.resource.size < 10 * 1024 * 1024
                    && request.resource.contentType == 'image/jpeg';
      allow update, delete: if false;
    }

    // Web (HCSD): Notice-to-Proceed document per project.
    // One NTP per project, overwrite permitted. Uploaded from CreateProject
    // as part of the three-step submit flow (createProject -> Storage write
    // -> attachNtp callable). Read open to any same-tenant signed-in user so
    // the assigned PE and other HCSD/MIS readers can view it.
    match /projects/{projectId}/ntp/{fileName} {
      allow read:  if request.auth != null
                   && firestore.get(
                        /databases/(default)/documents/projects/$(projectId)
                      ).data.tenantId == request.auth.token.tenantId;
      allow write: if request.auth != null
                   && request.auth.token.role == 'HCSD'
                   && firestore.get(
                        /databases/(default)/documents/projects/$(projectId)
                      ).data.tenantId == request.auth.token.tenantId
                   && request.resource.size < 10 * 1024 * 1024
                   && request.resource.contentType in ['application/pdf', 'image/jpeg', 'image/png'];
      allow delete: if false;
    }

    // Catch-all: signed-in reads, all other client writes blocked.
    match /{allPaths=**} {
      allow read:  if request.auth != null;
      allow write: if false;
    }
  }
}
